<Window x:Class="OTPilot.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About OTPilot"
        Width="360" Height="390"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>   <!-- Header        -->
            <RowDefinition Height="*"/>    <!-- Details       -->
            <RowDefinition Height="52"/>   <!-- Footer/close  -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#111827" Offset="0"/>
                    <GradientStop Color="#0F172A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Image Source="/Resources/OTPilot.ico"
                       Width="44" Height="44"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Margin="0,0,14,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontFamily="Bahnschrift"
                               FontSize="24" FontWeight="SemiBold">
                        <Run Text="OTP " Foreground="#00A0DF"/>
                        <Run Text="Pilot" Foreground="#F2F2F2"/>
                    </TextBlock>
                    <TextBlock x:Name="VersionText"
                               FontSize="10" Foreground="#00A0DF"
                               FontFamily="Bahnschrift SemiLight"
                               Margin="1,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Details -->
        <StackPanel Grid.Row="1" Margin="28,20,28,0">

            <TextBlock Text="A secure, roaming-friendly TOTP authenticator designed for enterprise hot-desk environments."
                       FontSize="12" Foreground="#475569" FontFamily="Segoe UI"
                       TextWrapping="Wrap" LineHeight="20"/>

            <Rectangle Height="1" Fill="#E2E8F0" Margin="0,16,0,16"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Developed by"
                           FontSize="12" Foreground="#94A3B8" FontFamily="Segoe UI"
                           Margin="0,0,16,10"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Eugene Myburgh"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#0F172A" FontFamily="Segoe UI"
                           Margin="0,0,0,10"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="License"
                           FontSize="12" Foreground="#94A3B8" FontFamily="Segoe UI"
                           Margin="0,0,16,10"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="MIT — Free &amp; Open Source"
                           FontSize="12" Foreground="#0F172A" FontFamily="Segoe UI"
                           Margin="0,0,0,10"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Source code"
                           FontSize="12" Foreground="#94A3B8" FontFamily="Segoe UI"
                           Margin="0,0,16,10"/>
                <TextBlock Grid.Row="2" Grid.Column="1"
                           x:Name="GithubText"
                           FontSize="12" Foreground="#2563EB" FontFamily="Segoe UI"
                           Cursor="Hand" TextDecorations="Underline" TextWrapping="Wrap"
                           MouseLeftButtonUp="GitHub_Click"
                           Margin="0,0,0,10"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Follow development"
                           FontSize="12" Foreground="#94A3B8" FontFamily="Segoe UI"
                           Margin="0,0,16,0"/>
                <TextBlock Grid.Row="3" Grid.Column="1"
                           x:Name="FollowText"
                           FontSize="12" Foreground="#2563EB" FontFamily="Segoe UI"
                           Cursor="Hand" TextDecorations="Underline" TextWrapping="Wrap"
                           MouseLeftButtonUp="Follow_Click"
                           Margin="0,0,0,0"/>
            </Grid>

        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F8FAFC"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="28,0">
            <Grid>
                <TextBlock x:Name="CopyrightText"
                           VerticalAlignment="Center"
                           FontSize="11" Foreground="#94A3B8" FontFamily="Segoe UI"/>
                <Button Content="Close"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Padding="20,7" FontSize="12" FontFamily="Segoe UI"
                        Cursor="Hand" Click="Close_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="False">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E2E8F0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

    </Grid>
</Window>
