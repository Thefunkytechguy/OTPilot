<Window x:Class="OTPilot.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OTP Pilot — Settings"
        Width="400" SizeToContent="Height"
        MinHeight="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Background="White">

    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="#94A3B8"/>
            <Setter Property="Margin"       Value="0,0,0,8"/>
        </Style>
        <Style x:Key="SettingsButton" TargetType="Button">
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#111827" Offset="0"/>
                    <GradientStop Color="#0F172A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock FontFamily="Bahnschrift" FontSize="20" FontWeight="SemiBold">
                    <Run Text="OTP " Foreground="#00A0DF"/>
                    <Run Text="Pilot" Foreground="#F2F2F2"/>
                </TextBlock>
                <TextBlock Text=" — Settings"
                           FontFamily="Bahnschrift SemiLight"
                           FontSize="14" Foreground="#94A3B8"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="24,20,24,8">

            <!-- ── Storage ─────────────────────────────────────── -->
            <TextBlock Text="STORAGE" Style="{StaticResource SectionLabel}"/>

            <Border Background="#F8FAFC" BorderBrush="#E2E8F0"
                    BorderThickness="1" CornerRadius="8"
                    Padding="16,14" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Storage location"
                                   FontFamily="Segoe UI" FontSize="13"
                                   FontWeight="SemiBold" Foreground="#111827"
                                   Margin="0,0,0,3"/>
                        <TextBlock x:Name="CurrentStorageText"
                                   FontFamily="Segoe UI" FontSize="11"
                                   Foreground="#6B7280"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            x:Name="ChangeStorageButton"
                            Content="Change…"
                            Style="{StaticResource SettingsButton}"
                            Background="White"
                            BorderBrush="#CBD5E1"
                            Foreground="#374151"
                            VerticalAlignment="Center"
                            Click="ChangeStorage_Click"/>
                </Grid>
            </Border>

            <!-- ── Import ──────────────────────────────────────── -->
            <TextBlock Text="IMPORT" Style="{StaticResource SectionLabel}"/>

            <Border Background="#F8FAFC" BorderBrush="#E2E8F0"
                    BorderThickness="1" CornerRadius="8"
                    Padding="16,14" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <TextBlock Text="Import from WinOTP"
                                       FontFamily="Segoe UI" FontSize="13"
                                       FontWeight="SemiBold" Foreground="#111827"/>
                            <Border Background="#FEF3C7" CornerRadius="4"
                                    Padding="6,2" Margin="8,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="Coming soon"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="#D97706"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Migrate your existing accounts from WinOTP automatically."
                                   FontFamily="Segoe UI" FontSize="11"
                                   Foreground="#6B7280" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="Import…"
                            Style="{StaticResource SettingsButton}"
                            Background="White"
                            BorderBrush="#CBD5E1"
                            Foreground="#374151"
                            VerticalAlignment="Center"
                            IsEnabled="False"/>
                </Grid>
            </Border>

        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#E2E8F0">
            <Button Content="Close"
                    IsDefault="True" IsCancel="True"
                    Width="90" Height="32"
                    HorizontalAlignment="Right"
                    Margin="0,0,20,0"
                    Style="{StaticResource SettingsButton}"
                    Background="#F1F5F9"
                    BorderBrush="#CBD5E1"
                    Foreground="#374151"
                    Click="Close_Click"/>
        </Border>
    </Grid>
</Window>
