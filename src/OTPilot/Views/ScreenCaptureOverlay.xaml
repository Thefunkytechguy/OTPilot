<Window x:Class="OTPilot.Views.ScreenCaptureOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Normal"
        Cursor="Cross"
        KeyDown="Window_KeyDown">

    <Grid>
        <!-- Frozen screenshot background -->
        <Image x:Name="ScreenshotImage"
               Stretch="Fill"
               IsHitTestVisible="False"/>

        <!-- Semi-dark overlay (shows selection area as "light" cutout) -->
        <Canvas x:Name="OverlayCanvas"
                Background="Transparent"
                MouseLeftButtonDown="Canvas_MouseDown"
                MouseMove="Canvas_MouseMove"
                MouseLeftButtonUp="Canvas_MouseUp">

            <!-- Dark mask panels (top, left, right, bottom) around the selection -->
            <Rectangle x:Name="MaskTop"    Fill="#88000000" Canvas.Left="0" Canvas.Top="0"/>
            <Rectangle x:Name="MaskBottom" Fill="#88000000" Canvas.Left="0"/>
            <Rectangle x:Name="MaskLeft"   Fill="#88000000" Canvas.Left="0"/>
            <Rectangle x:Name="MaskRight"  Fill="#88000000"/>

            <!-- Selection border -->
            <Rectangle x:Name="SelectionRect"
                       Stroke="#2563EB"
                       StrokeThickness="2"
                       StrokeDashArray="4,2"
                       Fill="Transparent"
                       Visibility="Collapsed"/>

            <!-- Instruction label (shown before selection starts) -->
            <Border x:Name="InstructionBanner"
                    Canvas.Left="0"
                    Canvas.Top="0"
                    Background="#CC111827"
                    Padding="16,10">
                <TextBlock Text="Click and drag to select the QR code area  •  ESC to cancel"
                           FontSize="13"
                           Foreground="White"
                           FontFamily="Segoe UI"/>
            </Border>
        </Canvas>
    </Grid>
</Window>
