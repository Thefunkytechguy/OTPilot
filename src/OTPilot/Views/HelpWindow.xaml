<Window x:Class="OTPilot.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OTP Pilot — Help"
        Width="400" Height="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#111827" Offset="0"/>
                    <GradientStop Color="#0F172A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock FontFamily="Bahnschrift" FontSize="20" FontWeight="SemiBold">
                    <Run Text="OTP " Foreground="#00A0DF"/>
                    <Run Text="Pilot" Foreground="#F2F2F2"/>
                </TextBlock>
                <TextBlock Text=" — Help"
                           FontFamily="Bahnschrift SemiLight"
                           FontSize="14" Foreground="#94A3B8"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,20,28,8">
            <StackPanel>

                <!-- Adding accounts -->
                <TextBlock Text="Adding an Account"
                           FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                           Foreground="#0F172A" Margin="0,0,0,6"/>
                <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12"
                           Foreground="#475569" LineHeight="20" Margin="0,0,0,4">
                    Click the <Run FontWeight="SemiBold" Foreground="#00A0DF">+</Run> button at the bottom right.
                </TextBlock>
                <TextBlock Text="• Scan QR Code — draw a rectangle around any QR code on your screen."
                           TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12"
                           Foreground="#475569" Margin="8,2,0,2"/>
                <TextBlock Text="• Manual Entry — type in the account name, issuer, and secret key provided by the service."
                           TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12"
                           Foreground="#475569" Margin="8,2,0,16"/>

                <Separator Background="#E2E8F0" Margin="0,0,0,16"/>

                <!-- Using codes -->
                <TextBlock Text="Using a Code"
                           FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                           Foreground="#0F172A" Margin="0,0,0,6"/>
                <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12"
                           Foreground="#475569" LineHeight="20" Margin="0,0,0,4">
                    Each account card shows a 6-digit code and a countdown timer. Click
                    <Run FontWeight="SemiBold">Copy</Run> to copy the code to your clipboard — it clears automatically after 30 seconds.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12"
                           Foreground="#475569" LineHeight="20" Margin="0,0,0,16">
                    The progress bar at the top shows how long until all codes refresh (every 30 seconds).
                </TextBlock>

                <Separator Background="#E2E8F0" Margin="0,0,0,16"/>

                <!-- Removing accounts -->
                <TextBlock Text="Removing an Account"
                           FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                           Foreground="#0F172A" Margin="0,0,0,6"/>
                <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12"
                           Foreground="#475569" LineHeight="20" Margin="0,0,0,16">
                    Click <Run FontWeight="SemiBold">Delete</Run> on the account card and confirm. This cannot be undone — make sure you no longer need the account before removing it.
                </TextBlock>

                <Separator Background="#E2E8F0" Margin="0,0,0,16"/>

                <!-- System tray -->
                <TextBlock Text="Closing the App"
                           FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                           Foreground="#0F172A" Margin="0,0,0,6"/>
                <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12"
                           Foreground="#475569" LineHeight="20" Margin="0,0,0,16">
                    Closing the window minimises OTP Pilot to the system tray — your codes are still accessible. Right-click the tray icon to exit completely.
                </TextBlock>

                <Separator Background="#E2E8F0" Margin="0,0,0,16"/>

                <!-- Storage -->
                <TextBlock Text="Where Are My Accounts Stored?"
                           FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                           Foreground="#0F172A" Margin="0,0,0,6"/>
                <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12"
                           Foreground="#475569" LineHeight="20" Margin="0,0,0,8">
                    If you chose <Run FontWeight="SemiBold">OneDrive for Business</Run> during setup, your accounts are encrypted and stored in your OneDrive — they follow you to any machine you sign into.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" FontFamily="Segoe UI" FontSize="12"
                           Foreground="#475569" LineHeight="20" Margin="0,0,0,16">
                    If you chose <Run FontWeight="SemiBold">Local Storage</Run>, accounts are stored on this machine only.
                </TextBlock>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#E2E8F0">
            <Button Content="Close"
                    IsDefault="True" IsCancel="True"
                    Width="90" Height="32"
                    HorizontalAlignment="Right"
                    Margin="0,0,20,0"
                    Click="Close_Click"
                    FontFamily="Segoe UI" FontSize="12"
                    Background="#F1F5F9" BorderThickness="1"
                    BorderBrush="#CBD5E1" Cursor="Hand"/>
        </Border>
    </Grid>
</Window>
