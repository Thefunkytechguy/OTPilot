<Window x:Class="OTPilot.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OTP Pilot — Help"
        Width="420" SizeToContent="Height" MaxHeight="640"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Background="White">

    <Window.Resources>

        <!-- Section header: blue left accent bar -->
        <Style x:Key="SectionHeader" TargetType="Border">
            <Setter Property="BorderBrush"     Value="#00A0DF"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="Padding"         Value="10,3,0,3"/>
            <Setter Property="Margin"          Value="0,0,0,8"/>
        </Style>

        <!-- Section heading text — bold, dark -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Foreground"  Value="#0F172A"/>
        </Style>

        <!-- Body copy -->
        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Foreground"   Value="#475569"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight"   Value="20"/>
        </Style>

        <!-- Numbered step circle -->
        <Style x:Key="StepNumber" TargetType="Border">
            <Setter Property="Background"        Value="#EFF6FF"/>
            <Setter Property="CornerRadius"      Value="10"/>
            <Setter Property="Width"             Value="20"/>
            <Setter Property="Height"            Value="20"/>
            <Setter Property="Margin"            Value="0,1,8,0"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="56"/>
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────── -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#111827" Offset="0"/>
                    <GradientStop Color="#0F172A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock FontFamily="Bahnschrift" FontSize="20" FontWeight="SemiBold">
                    <Run Text="OTP " Foreground="#00A0DF"/>
                    <Run Text="Pilot" Foreground="#F2F2F2"/>
                </TextBlock>
                <TextBlock Text=" — Help"
                           FontFamily="Bahnschrift SemiLight"
                           FontSize="14" Foreground="#94A3B8"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Content ────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      MaxHeight="500">
            <StackPanel Margin="24,20,24,16">

                <!-- Adding an Account -->
                <Border Style="{StaticResource SectionHeader}">
                    <TextBlock Text="Adding an Account" Style="{StaticResource SectionTitle}"/>
                </Border>
                <!-- Step 1 -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource StepNumber}">
                        <TextBlock Text="1" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#2563EB"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Style="{StaticResource BodyText}">
                        Click the <Run FontWeight="SemiBold" Foreground="#00A0DF">+</Run> button at the bottom right of the main window.
                    </TextBlock>
                </Grid>
                <!-- Step 2 -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource StepNumber}">
                        <TextBlock Text="2" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#2563EB"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,4">
                            Choose how to add the account:
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="12,0,0,3">
                            <Run FontWeight="SemiBold">Scan QR Code</Run> — draw a rectangle around the QR code on your screen. Works across all monitors.
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="12,0,0,0">
                            <Run FontWeight="SemiBold">Manual Entry</Run> — type in the account name, issuer, and the secret key provided by the service.
                        </TextBlock>
                    </StackPanel>
                </Grid>
                <!-- Step 3 -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource StepNumber}">
                        <TextBlock Text="3" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#2563EB"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Style="{StaticResource BodyText}">
                        Click <Run FontWeight="SemiBold">Add</Run> to save the account. It will appear on the main screen immediately.
                    </TextBlock>
                </Grid>

                <!-- Using a Code -->
                <Border Style="{StaticResource SectionHeader}">
                    <TextBlock Text="Using a Code" Style="{StaticResource SectionTitle}"/>
                </Border>
                <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,6">
                    Each account card displays a <Run FontWeight="SemiBold">6-digit code</Run> and a countdown timer showing seconds remaining.
                </TextBlock>
                <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,6">
                    Click <Run FontWeight="SemiBold">Copy</Run> to copy the code to your clipboard. The code clears automatically after 30 seconds for security.
                </TextBlock>
                <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,20">
                    The blue progress bar at the top of the window shows the time remaining before all codes refresh (every 30 seconds).
                </TextBlock>

                <!-- Removing an Account -->
                <Border Style="{StaticResource SectionHeader}">
                    <TextBlock Text="Removing an Account" Style="{StaticResource SectionTitle}"/>
                </Border>
                <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,20">
                    Click the <Run FontWeight="SemiBold">delete</Run> icon on the account card and confirm. This cannot be undone — make sure you no longer need the account before removing it.
                </TextBlock>

                <!-- Closing the App -->
                <Border Style="{StaticResource SectionHeader}">
                    <TextBlock Text="Closing the App" Style="{StaticResource SectionTitle}"/>
                </Border>
                <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,20">
                    Closing the window minimises OTP Pilot to the <Run FontWeight="SemiBold">system tray</Run> — your codes remain accessible. Right-click the tray icon to exit completely.
                </TextBlock>

                <!-- Storage -->
                <Border Style="{StaticResource SectionHeader}">
                    <TextBlock Text="Where Are My Accounts Stored?" Style="{StaticResource SectionTitle}"/>
                </Border>
                <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,6">
                    <Run FontWeight="SemiBold">OneDrive for Business</Run> — accounts are encrypted and stored in your OneDrive. They follow you automatically to any machine you sign into.
                </TextBlock>
                <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,20">
                    <Run FontWeight="SemiBold">Local Storage</Run> — accounts are stored on this machine only and will not follow you to other workstations.
                </TextBlock>

                <!-- Settings -->
                <Border Style="{StaticResource SectionHeader}">
                    <TextBlock Text="Changing Settings" Style="{StaticResource SectionTitle}"/>
                </Border>
                <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,4">
                    Click the <Run FontWeight="SemiBold">⚙ gear icon</Run> in the top bar to open Settings, where you can change your storage location.
                </TextBlock>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Footer ─────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="#F8FAFC"
                BorderBrush="#E2E8F0"
                BorderThickness="0,1,0,0"
                Padding="28,0">
            <Button Content="Close"
                    IsDefault="True" IsCancel="True"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Padding="20,7"
                    FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                    Foreground="#374151"
                    Cursor="Hand"
                    Click="Close_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="#F1F5F9"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#E2E8F0"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Border>

    </Grid>
</Window>
