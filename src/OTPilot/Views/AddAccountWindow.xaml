<Window x:Class="OTPilot.Views.AddAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Add Account — OTPilot"
        Width="380" Height="Auto"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <Window.Resources>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#2563EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="20,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#93C5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,9"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F9FAFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScanButton" TargetType="Button">
            <Setter Property="Background" Value="#F0F9FF"/>
            <Setter Property="Foreground" Value="#0369A1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="BorderBrush" Value="#BAE6FD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E0F2FE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <StackPanel Margin="24">

        <!-- Title -->
        <TextBlock Text="Add Account"
                   FontSize="18" FontWeight="Bold"
                   Foreground="#111827"
                   Margin="0,0,0,20"/>

        <!-- QR Scan button -->
        <Button Style="{StaticResource ScanButton}"
                Click="ScanQr_Click"
                Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📷" FontSize="16" Margin="0,0,8,0"/>
                <TextBlock Text="Scan QR Code from Screen" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

        <!-- Divider -->
        <Grid Margin="0,0,0,16">
            <Separator/>
            <Border Background="White" HorizontalAlignment="Center" Padding="10,0">
                <TextBlock Text="or enter manually"
                           FontSize="11" Foreground="#9CA3AF"/>
            </Border>
        </Grid>

        <!-- Issuer -->
        <TextBlock Text="Service Name (e.g. Microsoft, Google)" Style="{StaticResource Label}"/>
        <TextBox x:Name="IssuerBox"
                 Style="{StaticResource InputBox}"
                 Text="{Binding Issuer, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,14"/>

        <!-- Account Name -->
        <TextBlock Text="Account (email or username)" Style="{StaticResource Label}"/>
        <TextBox x:Name="AccountNameBox"
                 Style="{StaticResource InputBox}"
                 Text="{Binding AccountName, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,14"/>

        <!-- Secret Key -->
        <TextBlock Text="Secret Key" Style="{StaticResource Label}"/>
        <TextBox x:Name="SecretBox"
                 Style="{StaticResource InputBox}"
                 Text="{Binding Secret, UpdateSourceTrigger=PropertyChanged}"
                 FontFamily="Consolas"
                 CharacterCasing="Upper"
                 Margin="0,0,0,14"/>

        <!-- Advanced toggle -->
        <Button Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                HorizontalAlignment="Left"
                Click="ToggleAdvanced_Click"
                Margin="0,0,0,10">
            <TextBlock FontSize="12" Foreground="#2563EB">
                <Run x:Name="AdvancedArrow" Text="▶"/>
                <Run Text=" Advanced options"/>
            </TextBlock>
        </Button>

        <!-- Advanced section -->
        <StackPanel x:Name="AdvancedPanel" Visibility="Collapsed" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Algorithm" Style="{StaticResource Label}"/>
                    <ComboBox Style="{StaticResource ComboStyle}"
                              ItemsSource="{Binding AlgorithmOptions}"
                              SelectedItem="{Binding SelectedAlgorithm}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Digits" Style="{StaticResource Label}"/>
                    <ComboBox Style="{StaticResource ComboStyle}"
                              ItemsSource="{Binding DigitOptions}"
                              SelectedItem="{Binding Digits}"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="Period (s)" Style="{StaticResource Label}"/>
                    <ComboBox Style="{StaticResource ComboStyle}"
                              ItemsSource="{Binding PeriodOptions}"
                              SelectedItem="{Binding Period}"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Error message -->
        <Border x:Name="ErrorBorder"
                Background="#FEF2F2"
                BorderBrush="#FCA5A5"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,8"
                Margin="0,0,0,12"
                Visibility="Collapsed">
            <TextBlock x:Name="ErrorText"
                       FontSize="12"
                       Foreground="#DC2626"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Action buttons -->
        <Grid Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Style="{StaticResource SecondaryButton}"
                    Content="Cancel"
                    Click="Cancel_Click"/>

            <Button Grid.Column="2"
                    Style="{StaticResource PrimaryButton}"
                    Content="Add Account"
                    Click="Confirm_Click"
                    IsDefault="True"/>
        </Grid>

    </StackPanel>
</Window>
