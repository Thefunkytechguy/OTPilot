<Window x:Class="OTPilot.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:OTPilot.ViewModels"
        mc:Ignorable="d"
        Title="OTPilot"
        Width="360" Height="580"
        MinWidth="320" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6"
        Closing="Window_Closing">

    <Window.Resources>

        <!-- Accent colour converter -->
        <SolidColorBrush x:Key="SidebarBrush" Color="#111827"/>
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#2563EB"/>

        <!-- Sidebar icon button style -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1F2937"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#374151"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Account card style -->
        <Style x:Key="AccountCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="10,5,10,5"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1"
                                      Color="#000000" Opacity="0.08"
                                      Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Copy button style -->
        <Style x:Key="CopyButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F4F6"/>
                                <Setter Property="Foreground" Value="#111827"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Delete button style -->
        <Style x:Key="DeleteButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#D1D5DB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#EF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Progress bar style (slim, no animation) -->
        <Style x:Key="TimerProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border CornerRadius="0,0,6,6" Background="{TemplateBinding Background}">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="0,0,0,6"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="52"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ────────────────────────────────────────────────────── -->
        <Grid Grid.Column="0" Background="#111827">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- App logo / top icon -->
            <Border Grid.Row="0" Height="52" Background="#2563EB">
                <TextBlock Text="O" FontSize="22" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Add account button -->
            <StackPanel Grid.Row="1" VerticalAlignment="Top" Margin="0,8,0,0">
                <Button Style="{StaticResource SidebarButton}"
                        ToolTip="Add Account"
                        Click="AddAccount_Click">
                    <TextBlock Text="+" FontSize="24" FontWeight="Light"/>
                </Button>
            </StackPanel>

            <!-- Bottom actions -->
            <StackPanel Grid.Row="2" VerticalAlignment="Bottom" Margin="0,0,0,8">
                <Button Style="{StaticResource SidebarButton}"
                        ToolTip="About OTPilot"
                        Click="About_Click">
                    <TextBlock Text="?" FontSize="16" FontWeight="Bold"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ── Main content area ─────────────────────────────────────────── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header bar -->
                <RowDefinition Height="4"/>      <!-- Global timer strip -->
                <RowDefinition Height="*"/>      <!-- Account list -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="White" Padding="14,10">
                <Grid>
                    <TextBlock Text="Accounts"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#111827"
                               VerticalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="11" Foreground="#9CA3AF">
                        <Run Text="{Binding GlobalSecondsRemaining, Mode=OneWay}"/>
                        <Run Text="s"/>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Global timer bar -->
            <ProgressBar Grid.Row="1"
                         Value="{Binding GlobalProgress, Mode=OneWay}"
                         Minimum="0" Maximum="100"
                         Foreground="#2563EB"
                         Background="#E5E7EB"
                         BorderThickness="0"
                         Height="4"/>

            <!-- Account list -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,5,0,10">

                <!-- Empty state -->
                <Grid>
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="30"
                                Visibility="{Binding HasAccounts, Converter={StaticResource InverseBoolToVisibility}}">
                        <TextBlock Text="No accounts yet"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="#6B7280"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Click the + button to add your first account."
                                   FontSize="12" Foreground="#9CA3AF"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Account cards -->
                    <ItemsControl ItemsSource="{Binding Accounts}"
                                  Visibility="{Binding HasAccounts, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate d:DataType="{x:Type vm:AccountViewModel}">
                                <Border Style="{StaticResource AccountCard}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="3"/>  <!-- Per-card timer -->
                                        </Grid.RowDefinitions>

                                        <!-- Card content -->
                                        <Grid Grid.Row="0" Margin="0,10,10,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Accent bar -->
                                            <Rectangle Grid.Column="0"
                                                       Fill="{Binding AccentBrush}"
                                                       VerticalAlignment="Stretch"
                                                       RadiusX="2" RadiusY="2"/>

                                            <!-- Text content -->
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Issuer}"
                                                           FontSize="11"
                                                           Foreground="#6B7280"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding FormattedCode}"
                                                           FontSize="28"
                                                           FontWeight="Bold"
                                                           Foreground="#111827"
                                                           FontFamily="Consolas, Courier New"
                                                           Margin="0,2,0,2"/>
                                                <TextBlock Text="{Binding AccountName}"
                                                           FontSize="11"
                                                           Foreground="#9CA3AF"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <!-- Actions -->
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Vertical"
                                                        VerticalAlignment="Center">
                                                <Button Style="{StaticResource CopyButton}"
                                                        Content="Copy"
                                                        Click="CopyCode_Click"
                                                        Tag="{Binding}"/>
                                                <Button Style="{StaticResource DeleteButton}"
                                                        Content="✕"
                                                        Click="DeleteAccount_Click"
                                                        Tag="{Binding}"
                                                        Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Per-card countdown bar -->
                                        <ProgressBar Grid.Row="1"
                                                     Value="{Binding Progress, Mode=OneWay}"
                                                     Minimum="0" Maximum="100"
                                                     Foreground="{Binding AccentBrush}"
                                                     Style="{StaticResource TimerProgressBar}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
